<!-- The New UI appearance of Berth: design tokens (BerthThemeKeys) per theme variant plus
     pseudo-class styles for the states the tokens cannot express. Reference values are the
     IntelliJ IDEA New UI palette (docs/reference/idea-tracing-visual.md); deliberate
     fidelity compromises are documented in docs/styling.md. The active-panel accent lives
     on the stripe icon (StripeButton:active, the solid blue of the reference), while the
     header accent is neutralized: BerthActiveHeaderBrush equals BerthPaneBrush — in the
     reference the colored header is dead old-UI code. Selector styles ride at StyleTrigger
     priority, above the library's Template-priority token bindings (docs/styling.md). -->
<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:berth="using:Berth.Controls"
        x:Class="Berth.Themes.NewUi.BerthNewUiTheme">
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="BerthPaneBrush" Color="#F7F8FA"/>
          <SolidColorBrush x:Key="BerthSeparatorBrush" Color="#EBECF0"/>
          <SolidColorBrush x:Key="BerthOpenIconBrush" Color="#1D000000"/>
          <!-- Equals BerthPaneBrush: the New UI accent of the active panel is the stripe
               icon, never the header. -->
          <SolidColorBrush x:Key="BerthActiveHeaderBrush" Color="#F7F8FA"/>
          <!-- The uniform IDE canvas (§6 of the reference): one background under the whole
               workspace — the black gaps of the default transparent canvas disappear. -->
          <SolidColorBrush x:Key="BerthWorkspaceBackgroundBrush" Color="#F7F8FA"/>
          <SolidColorBrush x:Key="BerthDropMarkerBrush" Color="#709CF5"/>
          <SolidColorBrush x:Key="BerthDropAreaPreviewBrush" Color="#4DA0BDF8"/>
          <SolidColorBrush x:Key="BerthOverlaySurfaceBrush" Color="#F7F8FA"/>
          <!-- Implementation keys of this theme's own state styles, not part of the Berth
               token contract. -->
          <SolidColorBrush x:Key="BerthNewUiStripeHoverBrush" Color="#12000000"/>
          <SolidColorBrush x:Key="BerthNewUiTabHoverBrush" Color="#EBECF0"/>
          <!-- Tab underline of the reference (§7, editor and tool window tabs alike):
               the inactive shade is per-variant, the focused blue is one hex in both. -->
          <SolidColorBrush x:Key="BerthNewUiTabInactiveUnderlineBrush" Color="#A8ADBD"/>
          <!-- Editor tabs sit on their own surface (§7): white / Gray1, not the pane. -->
          <SolidColorBrush x:Key="BerthDocumentTabStripBrush" Color="#FFFFFF"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="BerthPaneBrush" Color="#2B2D30"/>
          <SolidColorBrush x:Key="BerthSeparatorBrush" Color="#1E1F22"/>
          <SolidColorBrush x:Key="BerthOpenIconBrush" Color="#26FFFFFF"/>
          <SolidColorBrush x:Key="BerthActiveHeaderBrush" Color="#2B2D30"/>
          <SolidColorBrush x:Key="BerthWorkspaceBackgroundBrush" Color="#2B2D30"/>
          <SolidColorBrush x:Key="BerthDropMarkerBrush" Color="#548AF7"/>
          <SolidColorBrush x:Key="BerthDropAreaPreviewBrush" Color="#4D366ACF"/>
          <SolidColorBrush x:Key="BerthOverlaySurfaceBrush" Color="#2B2D30"/>
          <SolidColorBrush x:Key="BerthNewUiStripeHoverBrush" Color="#16FFFFFF"/>
          <SolidColorBrush x:Key="BerthNewUiTabHoverBrush" Color="#393B40"/>
          <SolidColorBrush x:Key="BerthNewUiTabInactiveUnderlineBrush" Color="#5A5D63"/>
          <SolidColorBrush x:Key="BerthDocumentTabStripBrush" Color="#1E1F22"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <!-- The selected-stripe-icon fill and the focused-tab underline are one hex in both
           variants (= the reference). -->
      <SolidColorBrush x:Key="BerthNewUiStripeActiveBrush" Color="#3574F0"/>
      <SolidColorBrush x:Key="BerthNewUiTabUnderlineBrush" Color="#3574F0"/>

      <!-- Size tokens, variant-independent. Splitters: the reference paints a 0 px divider
           with an invisible 6 px grab overlay; a Berth splitter is one entity (visual =
           grab), so the theme keeps the reference hairline look at the cost of a narrow
           grab — the split entity is a backlog candidate (owner decision, 2026-07-22). -->
      <x:Double x:Key="BerthStripeWidth">40</x:Double>
      <x:Double x:Key="BerthStripeButtonSize">30</x:Double>
      <x:Double x:Key="BerthHeaderHeight">41</x:Double>
      <x:Double x:Key="BerthTabStripHeight">41</x:Double>
      <x:Double x:Key="BerthSplitterThickness">1</x:Double>

      <!-- Every tab of the reference speaks the underline (§7): editor tabs and tool
           window content tabs alike — selection is the bottom underline, never a fill.
           The underline color rides on the header's BorderBrush (surfaced here by
           TemplateBinding), so the state styles below the ControlTheme can set it without
           reaching into the template; heights differ per host kind (editor 4, tool
           window 3). Replacing leaf-chrome templates is the legal channel of the styling
           contract (docs/styling.md). -->
      <ControlTheme x:Key="{x:Type berth:DockTabHeader}" TargetType="berth:DockTabHeader">
        <Setter Property="Padding" Value="8,0,2,0"/>
        <Setter Property="Template">
          <ControlTemplate>
            <Panel>
              <Border Background="{TemplateBinding Background}"
                      Padding="{TemplateBinding Padding}">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{TemplateBinding Title}" VerticalAlignment="Center"/>
                  <berth:BerthChromeButton Name="PART_TabClose" Content="×"/>
                </StackPanel>
              </Border>
              <Border Name="UnderlineBar"
                      Height="3"
                      CornerRadius="2"
                      VerticalAlignment="Bottom"
                      Background="{TemplateBinding BorderBrush}"
                      IsVisible="False"/>
            </Panel>
          </ControlTemplate>
        </Setter>
        <Style Selector="^:active /template/ Border#UnderlineBar">
          <Setter Property="IsVisible" Value="True"/>
        </Style>
        <Style Selector="^:document /template/ Border#UnderlineBar">
          <Setter Property="Height" Value="4"/>
        </Style>
      </ControlTheme>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- Hover of a closed stripe icon; an open one keeps its stronger token highlight. -->
  <Style Selector="berth|StripeButton:pointerover:not(:open)">
    <Setter Property="Background" Value="{DynamicResource BerthNewUiStripeHoverBrush}"/>
  </Style>

  <!-- The New UI active-panel accent: the solid blue fill of the selected stripe icon. -->
  <Style Selector="berth|StripeButton:active">
    <Setter Property="Background" Value="{DynamicResource BerthNewUiStripeActiveBrush}"/>
  </Style>

  <!-- Selection is never a fill (§7: underlinedTabBackground is the bar itself), so the
       library's :active/:current token fills are overridden flat; the only background
       state left is the hover of tool window tabs — editor-tab hover is alpha 00. -->
  <Style Selector="berth|DockTabHeader:document">
    <Setter Property="Background" Value="Transparent"/>
  </Style>
  <Style Selector="berth|DockTabHeader:active">
    <Setter Property="Background" Value="Transparent"/>
  </Style>
  <Style Selector="berth|DockTabHeader:pointerover:not(:document):not(:active)">
    <Setter Property="Background" Value="{DynamicResource BerthNewUiTabHoverBrush}"/>
  </Style>

  <!-- The underline colors, riding on BorderBrush (see the ControlTheme). Order matters —
       Avalonia resolves equal matches by declaration order: the dimmed base first, then
       the focused blue of a selected tab inside the active tool window, then the focused
       blue of the current document (its header carries :active too). -->
  <Style Selector="berth|DockTabHeader:active">
    <Setter Property="BorderBrush" Value="{DynamicResource BerthNewUiTabInactiveUnderlineBrush}"/>
  </Style>
  <Style Selector="berth|ToolWindowDecorator:active berth|DockTabHeader:active">
    <Setter Property="BorderBrush" Value="{DynamicResource BerthNewUiTabUnderlineBrush}"/>
  </Style>
  <Style Selector="berth|DockTabHeader:current">
    <Setter Property="BorderBrush" Value="{DynamicResource BerthNewUiTabUnderlineBrush}"/>
  </Style>
</Styles>
