<UserControl xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:Berth.Demo.ViewModels"
                xmlns:berth="using:Berth.Controls"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:Class="Berth.Demo.Views.MainView"
                x:DataType="vm:MainViewModel">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainViewModel />
    </Design.DataContext>

    <!-- State is two-way: workspace gestures assign the command result back and the view
         model observes it (persistence hooks onto this property in a real application).
         The demo keymap (Alt+1..Alt+4 -> ActivateToolWindow) and the shortcut hint
         provider are wired in code-behind: shortcuts live in the application (TW-5.5). -->
    <berth:BerthWorkspace x:Name="Workspace"
                          State="{Binding State, Mode=TwoWay}"
                          Registry="{Binding Registry}"
                          Lifecycle="{Binding Lifecycle}"/>
</UserControl>
