<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Berth.Demo"
             xmlns:newui="using:Berth.Themes.NewUi"
             x:Class="Berth.Demo.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <!-- Stripe icon resolved by ToolWindowDescriptor.IconKey (ADR-0003: the core stores
             the key, the application supplies the image). -->
        <DrawingImage x:Key="ProjectIcon">
            <GeometryDrawing Brush="#7F8B99"
                             Geometry="M2,3 L8,3 L10,5 L18,5 C18.6,5 19,5.4 19,6 L19,15 C19,15.6 18.6,16 18,16 L2,16 C1.4,16 1,15.6 1,15 L1,4 C1,3.4 1.4,3 2,3 Z"/>
        </DrawingImage>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <!-- The ready-made New UI appearance package: the demo doubles as its showcase. -->
        <newui:BerthNewUiTheme />
    </Application.Styles>
</Application>